<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Noisebuilder Blog</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  {% include "header.njk" %}

  <div class="main">
    <div class="content">
      {% for post in collections.post | reverse %}
        <article>
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          <p>{{ post.templateContent | safe }}</p> <!-- Afficher le contenu sans la date -->
        </article>
      {% else %}
        <p>Aucun article à afficher pour le moment.</p>
      {% endfor %}
    </div>

    {% include "sidebar.njk" %}
  </div>
</body>
</html>
